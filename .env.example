# Required for PostgreSQL connection (Prisma 7 reads this from prisma.config.ts)
DATABASE_URL="postgresql://user:password@localhost:5432/zipline"

# Optional PostgreSQL pool tuning for the web app.
DATABASE_POOL_MAX="10"
DATABASE_POOL_IDLE_TIMEOUT_MS="30000"
DATABASE_POOL_CONNECTION_TIMEOUT_MS="5000"
DATABASE_STATEMENT_TIMEOUT_MS="15000"

# Required for session token signing. Production rejects missing/default/short values.
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional: set to 1 to disable local demo login fallback in development.
DISABLE_DEV_AUTH_FALLBACK="0"

# Optional app metadata
NEXT_PUBLIC_APP_NAME="Zipline Command Center"

# AI API keys (not required for local dashboard operation)
MINIMAX_API_KEY="replace-me"
MINIMAX_MODEL="MiniMax-M2.7"
